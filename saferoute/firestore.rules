rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users – only the owner can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Trips – owner scoped
    match /trips/{tripId} {
      allow read: if request.auth != null
                   && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                     && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                             && resource.data.userId == request.auth.uid;
    }

    // Reports – any authenticated user can read; owner can create
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                             && resource.data.userId == request.auth.uid;
    }

    // Alerts – any authenticated user can read
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // admin-only via console / functions
    }

    // Sustainability – owner scoped
    match /sustainability/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Analytics – public read for authenticated users, write via service only
    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // tighten to admin in production
    }

    // Crowd reports – authenticated read/create
    match /crowdReports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
